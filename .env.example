# ==========================================
# PYPE PHP FRAMEWORK V2.5.5 — Environment
# ==========================================
# Copy this file to .env and fill in your values.
# Lines starting with # are commented out (optional).

# ==========================================
# APPLICATION
# ==========================================
APP_ENV=development          # Options: development, production, testing
APP_DEBUG=true               # Show detailed errors (disable in production)
APP_URL=http://localhost:8000
APP_KEY=base64:YourRandom32CharKeyHere  # Used for encryption, sessions, signed URLs

# ==========================================
# DATABASE
# ==========================================
DB_TYPE=sqlite               # Options: mysql, sqlite, postgresql

# MySQL / PostgreSQL settings (uncomment if using)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=your_database
# DB_USER=root
# DB_PASS=your_password

# SQLite settings (only needed for SQLite)
DB_PATH=database.sqlite

# ==========================================
# SESSION
# ==========================================
SESSION_LIFETIME=120         # Session lifetime in minutes
SESSION_SECURE=false         # Set true in production (requires HTTPS)

# ==========================================
# MAIL
# ==========================================
MAIL_DRIVER=log              # Options: smtp, log, mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME="App Name"

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=error              # Options: debug, info, warning, error, critical
LOG_CHANNEL=file             # Options: file, stdout

# ==========================================
# STORAGE / FILE DISKS
# ==========================================
FILESYSTEM_DISK=local        # Default disk: local, s3, cloudinary, gcs, azure

# Local Storage
STORAGE_PATH=Storage/uploads

# AWS S3 / MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=                # Optional: for MinIO or S3-compatible services

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY=

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_CONTAINER=

# CDN
CDN_URL=                     # Optional: https://cdn.yoursite.com

# ==========================================
# ENCRYPTION & SECURITY
# ==========================================
JWT_SECRET=YourRandomJwtSecretKeyAtLeast32Chars

# Password Policy (strength level)
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true

# Brute Force Protection
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_MINUTES=15

# ==========================================
# OAUTH / SOCIAL LOGIN
# ==========================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback

# Apple OAuth (Not implemented yet)
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_CLIENT_SECRET=your_apple_client_secret

# ==========================================
# PAYMENT GATEWAYS (E-Commerce)
# ==========================================

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox          # Options: sandbox, live

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ==========================================
# ANALYTICS (Optional)
# ==========================================
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=