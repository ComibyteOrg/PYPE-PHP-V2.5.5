{
    "name": "comibyte/pype-php",
    "description": "Pype PHP Framework - Modern, Fast, Beginner-Friendly",
    "type": "project",
    "license": "MIT",
    "php": ">=8.2",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-gd": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Framework\\": "Framework/",
            "App\\": "App/"
        },
        "files": [
            "Framework/Helper/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "lint": "phpcs --standard=PSR12 Framework/ App/",
        "lint:fix": "phpcbf --standard=PSR12 Framework/ App/"
    }
}
